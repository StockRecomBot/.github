# Server
TZ=Asia/Kolkata
VITE_API_URL=http://localhost:4001
BACKEND_PORT=4001
FRONTEND_PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# PostgreSQL
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=trading_recommendations
DB_USER=postgres
DB_PASSWORD=Some_token
DB_SCHEMA=public
DB_SSL=false
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# App behaviour
TRADE_UPDATE_CRON=0/5 9-16 * * 1-5
INGESTION_CRON=0 8-17 * * 1-5
PRICE_UPDATE_CRON=0/5 9-16 * * 1-5
MAX_LOSS_PER_TRADE_PERCENTAGE=5
HTTP_TIMEOUT_MS=30000


# Kite Connect (real-time WebSocket price updates for REAL trades)
KITE_API_KEY=Some_token
KITE_ACCESS_TOKEN=Some_token
KITE_TICKER_ENABLED=true

# Healthchecks.io (leave base URL empty to disable all pings)
HEALTHCHECK_BASE_URL=http://host.docker.internal:8000
HEALTHCHECK_INGESTION_SLUG=12aafcae-dabe-4fe2-822f-4578f4c23873
HEALTHCHECK_PRICE_UPDATE_SLUG=5c84485c-ab87-467d-90cc-2b1b29cbd74c
HEALTHCHECK_TRADE_EVALUATION_SLUG=4b5b2562-f6d3-413a-8cf1-3125b31a540d
HEALTHCHECK_ET_EXTRACTOR_SLUG=9c440ab9-de4c-481a-99e6-a88378781bf8
HEALTHCHECK_TRENDLYNE_EXTRACTOR_SLUG=05364001-613b-4c19-aa0b-21914c0068fc